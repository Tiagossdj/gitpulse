{
    "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
    "organizeImports": {
      "enabled": true
    },
    "linter": {
      "enabled": true,
      "rules": {
        "recommended": true,
        "suspicious": {
          "noExplicitAny": "error",
          "noArrayIndexKey": "off" 
        },
        "a11y": {
          "noAutofocus": "off"
        },
        "correctness": {
          "noUnknownMediaFeatureName": "off"
        }
      },
      "ignore": [
        "**/node_modules/**",
        "**/dist/**",
        "**/.next/**",
        "**/build/**",
        "**/globals.css"
      ]
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "lineWidth": 80,
      "ignore": [
        "**/node_modules/**",
        "**/dist/**",
        "**/.next/**",
        "**/build/**",
        "**/globals.css"
      ]
    }
  }