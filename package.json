{
  "name": "gitpulse",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": "pnpm exec biome check --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
